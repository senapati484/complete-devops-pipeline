# Database (PostgreSQL runs on EC2 host, not in Docker)
# The app container reaches it via host.docker.internal
DATABASE_URL="postgresql://postgres:senapati484@host.docker.internal:5432/devops_dashboard"

JWT_SECRET="your-random-32-char-secret-here"

# NextAuth (optional, used if you enable NextAuth)
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://YOUR_EC2_PUBLIC_IP"

# Environment
NODE_ENV=production
