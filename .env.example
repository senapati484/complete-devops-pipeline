# Database (PostgreSQL runs in Docker Compose — hostname is the service name)
# POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB injected via Jenkins credentials
DATABASE_URL="postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/devops_dashboard"

JWT_SECRET="your-random-32-char-secret-here"

# NextAuth (optional)
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://YOUR_EC2_PUBLIC_IP"

# Environment
NODE_ENV=production
